<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0"
            prefWidth="620.0"
            style="-fx-background-color: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controlador.DificilController">

   <children>

      <!-- TITULO -->
      <Label layoutX="200.0"
             layoutY="15.0"
             text="🔥 MODO DIFÍCIL"
             style="-fx-text-fill: #00e5ff;
                    -fx-font-size: 22px;
                    -fx-font-weight: bold;" />

      <!-- CRONOMETRO -->
      <Label fx:id="lb_cronometro"
             layoutX="30.0"
             layoutY="50.0"
             text="⏱ TIEMPO: 03:00"
             style="-fx-text-fill: #ffea00;
                    -fx-font-size: 14px;
                    -fx-font-weight: bold;" />

      <!-- INTENTOS -->
      <Label fx:id="lb_intentos"
             layoutX="450.0"
             layoutY="50.0"
             text="💀 INTENTOS: 3"
             style="-fx-text-fill: #ff5252;
                    -fx-font-size: 14px;
                    -fx-font-weight: bold;" />

      <!-- TABLA -->
      <TableView fx:id="tablenumbers"
                 layoutX="130.0"
                 layoutY="90.0"
                 prefHeight="210.0"
                 prefWidth="360.0"
                 style="-fx-background-color: #1e1e2f;
                        -fx-control-inner-background: #1e1e2f;
                        -fx-table-cell-border-color: #00e5ff;
                        -fx-border-color: #00e5ff;
                        -fx-text-fill: white;
                        -fx-selection-bar: #00e5ff;
                        -fx-selection-bar-text: black;
                        -fx-background-radius: 10;
                        -fx-border-radius: 10;">

         <columns>
            <TableColumn prefWidth="120.0" text="# INGRESADO" />
            <TableColumn prefWidth="120.0" text="RESULTADO" />
            <TableColumn prefWidth="120.0" text="ESTADO" />
         </columns>
      </TableView>

      <!-- MENSAJE -->
      <Label layoutX="130.0"
             layoutY="315.0"
             text="⚠ EN ESTE NIVEL NO HAY PISTAS ⚠"
             style="-fx-text-fill: #ff5252;
                    -fx-font-size: 13px;
                    -fx-font-weight: bold;" />

      <!-- BOTON VERIFICAR -->
      <Button fx:id="btn_verificar"
              layoutX="250.0"
              layoutY="355.0"
              text="VERIFICAR"
              onAction="#hadlebutton"
              style="-fx-background-color: #00e5ff;
                     -fx-text-fill: black;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;" />

      <!-- BOTON REINICIAR -->
      <Button fx:id="reinici"
              layoutX="370.0"
              layoutY="355.0"
              text="REINICIAR"
              onAction="#hadledificil"
              style="-fx-background-color: #ff1744;
                     -fx-text-fill: white;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;" />

      <!-- FOOTER -->
      <Label layoutX="20.0"
             layoutY="395.0"
             text="Nivel avanzado"
             style="-fx-text-fill: #bbbbbb;
                    -fx-font-size: 12px;" />

   </children>

</AnchorPane>