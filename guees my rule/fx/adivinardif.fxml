<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0"
            prefWidth="620.0"
            style="-fx-background-color: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controlador.AdivinardifController">

   <children>

      <!-- TITULO -->
      <Label layoutX="150.0"
             layoutY="20.0"
             text="ADIVINA LA REGLA - DIFÍCIL"
             style="-fx-text-fill: #00e5ff;
                    -fx-font-size: 24px;
                    -fx-font-weight: bold;" />

      <!-- BOTON REGLAS -->
      <Button layoutX="480.0"
              layoutY="20.0"
              text="REGLAS"
              onAction="#handleReglas"
              style="-fx-background-color: linear-gradient(to right, #ff9800, #ff5722);
                     -fx-text-fill: white;
                     -fx-font-weight: bold;
                     -fx-background-radius: 12;" />

      <!-- TEXTO -->
      <Label layoutX="130.0"
             layoutY="60.0"
             text="Analiza los ejemplos y descubre la regla"
             style="-fx-text-fill: white;
                    -fx-font-size: 14px;" />

      <!-- INPUT -->
      <TextField fx:id="txtNumero"
                 layoutX="180.0"
                 layoutY="90.0"
                 prefWidth="260.0"
                 promptText="Ej: 6"
                 style="-fx-background-color: #1e1e2f;
                        -fx-text-fill: #00e5ff;
                        -fx-border-color: #00e5ff;
                        -fx-border-radius: 10;
                        -fx-background-radius: 10;
                        -fx-prompt-text-fill: #888;
                        -fx-font-size: 14px;" />

      <!-- TABLA -->
      <TableView fx:id="tablaRegla"
                 layoutX="160.0"
                 layoutY="140.0"
                 prefHeight="200.0"
                 prefWidth="300.0"
                 style="-fx-background-color: #1e1e2f;
                        -fx-control-inner-background: #1e1e2f;
                        -fx-table-cell-border-color: #00e5ff;
                        -fx-border-color: #00e5ff;
                        -fx-border-radius: 12;
                        -fx-background-radius: 12;
                        -fx-text-fill: white;">
         
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         
         <columns>
            <TableColumn fx:id="colEntrada"
                         prefWidth="150.0"
                         text="ENTRADA"
                         style="-fx-alignment: CENTER; -fx-text-fill: white;" />
                         
            <TableColumn fx:id="colSalida"
                         prefWidth="150.0"
                         text="SALIDA"
                         style="-fx-alignment: CENTER; -fx-text-fill: white;" />
         </columns>
      </TableView>

      <!-- BOTON -->
      <Button layoutX="250.0"
              layoutY="360.0"
              text="ESTOY LISTO"
              onAction="#handleEstoyListo"
              style="-fx-background-color: #ff1744;
                     -fx-text-fill: white;
                     -fx-font-weight: bold;
                     -fx-background-radius: 15;
                     -fx-font-size: 14px;" />

   </children>

</AnchorPane>