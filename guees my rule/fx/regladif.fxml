<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0"
            prefWidth="620.0"
            style="-fx-background-color: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controlador.RegladifController">

   <children>

      <!-- TITULO -->
      <Label layoutX="210.0"
             layoutY="20.0"
             text="REGLAS MODO DIFÍCIL"
             style="-fx-text-fill: #00e5ff;
                    -fx-font-size: 22px;
                    -fx-font-weight: bold;" />

      <!-- AREA DE TEXTO -->
      <TextArea fx:id="txtReglas"
                layoutX="40.0"
                layoutY="70.0"
                prefWidth="540.0"
                prefHeight="260.0"
                editable="false"
                wrapText="true"
                style="-fx-control-inner-background: #1e1e2f;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-border-color: #00e5ff;
                       -fx-border-radius: 10;
                       -fx-background-radius: 10;" />

      <!-- BOTON CERRAR -->
      <Button layoutX="260.0"
              layoutY="350.0"
              text="CERRAR"
              onAction="#cerrarVentana"
              style="-fx-background-color: #ff1744;
                     -fx-text-fill: white;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;" />

   </children>

</AnchorPane>