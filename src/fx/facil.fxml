<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0"
            prefWidth="620.0"
            style="-fx-background-color: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controlador.PruebaController">

   <children>

     

      <!-- TITULO -->
      <Label layoutX="242.0"
             layoutY="30.0"
             text="MODO FACIL"
             style="-fx-text-fill: #00e5ff;
                    -fx-font-size: 22px;
                    -fx-font-weight: bold;" />

      <!-- INTENTOS -->
      <Label fx:id="lb_intentos"
             layoutX="460"
             layoutY="20"
             text="Intentos: 5"
             style="-fx-text-fill: #ffea00;
                    -fx-font-size: 16px;
                    -fx-font-weight: bold;" />

      <!-- TEXTO -->
      <Label layoutX="230"
             layoutY="70"
             text="Ingresa un número"
             style="-fx-text-fill: white;
                    -fx-font-size: 14px;" />

      <!-- INPUT -->
      <TextField fx:id="intenoone"
                 layoutX="210"
                 layoutY="95"
                 prefWidth="200"
                 onAction="#hadlerespuesta"
                 style="-fx-background-color: #1e1e2f;
                        -fx-text-fill: white;
                        -fx-border-color: #00e5ff;
                        -fx-border-radius: 10;
                        -fx-background-radius: 10;" />

      <!-- TABLA -->
      <TableView fx:id="tablenumbers"
                 layoutX="180"
                 layoutY="150"
                 prefHeight="180"
                 prefWidth="240"
                 style="-fx-background-color: #1e1e2f;
                        -fx-control-inner-background: #1e1e2f;
                        -fx-table-cell-border-color: #00e5ff;
                        -fx-border-color: #00e5ff;
                        -fx-text-background-color: white;
                        -fx-selection-bar: #00e5ff;
                        -fx-selection-bar-text: black;
                        -fx-background-radius: 10;
                        -fx-border-radius: 10;">
         <columns>
            <TableColumn prefWidth="120" text="# INGRESADO" />
            <TableColumn prefWidth="120" text="RESULTADO" />
         </columns>
      </TableView>

      <!-- BOTON VERIFICAR -->
      <Button fx:id="veri"
              layoutX="440"
              layoutY="200"
              text="VERIFICAR"
              onAction="#button_veri"
              style="-fx-background-color: #00e5ff;
                     -fx-text-fill: black;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;" />

      <!-- BOTON REINICIAR -->
      <Button fx:id="reini"
              layoutX="250"
              layoutY="350"
              text="REINICIAR"
              onAction="#buttonreiniciar"
              style="-fx-background-color: #ff1744;
                     -fx-text-fill: white;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;" />

      <!-- BOTON PISTA -->
      <Button fx:id="pista"
              layoutX="450"
              layoutY="350"
              text="PISTA"
              onAction="#hadel_pista"
              style="-fx-background-color: #00e676;
                     -fx-text-fill: black;
                     -fx-font-weight: bold;
                     -fx-background-radius: 10;" />

      <!-- FOOTER -->
      <Label layoutX="20"
             layoutY="390"
             text="Sin límite de tiempo"
             style="-fx-text-fill: #bbbbbb;
                    -fx-font-size: 12px;" />

   </children>

</AnchorPane>
