<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0"
            prefWidth="620.0"
            style="-fx-background-color: linear-gradient(to bottom, #0f0c29, #302b63, #24243e);"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controlador.PuntajeController">

   <children>

      <!-- TITULO -->
      <Label layoutX="220.0"
             layoutY="30.0"
             text="🏆 PUNTAJE FINAL"
             style="-fx-text-fill: #00e5ff;
                    -fx-font-size: 26px;
                    -fx-font-weight: bold;" />

      <!-- MENSAJE -->
      <Label layoutX="170.0"
             layoutY="90.0"
             text="¡PARTIDA TERMINADA!"
             style="-fx-text-fill: white;
                    -fx-font-size: 18px;
                    -fx-font-weight: bold;" />

      <!-- APODO -->
      <Label layoutX="120.0"
             layoutY="150.0"
             text="Jugador:"
             style="-fx-text-fill: #bbbbbb;
                    -fx-font-size: 18px;" />

      <Label fx:id="lbJugador"
             layoutX="250.0"
             layoutY="150.0"
             text="DORIS"
             style="-fx-text-fill: #00e5ff;
                    -fx-font-size: 20px;
                    -fx-font-weight: bold;" />

      <!-- PUNTAJE -->
      <Label layoutX="120.0"
             layoutY="210.0"
             text="Puntaje:"
             style="-fx-text-fill: #bbbbbb;
                    -fx-font-size: 18px;" />

      <Label fx:id="lbPuntaje"
             layoutX="250.0"
             layoutY="210.0"
             text="100"
             style="-fx-text-fill: #00e676;
                    -fx-font-size: 28px;
                    -fx-font-weight: bold;" />

      <!-- NIVEL -->
      <Label layoutX="120.0"
             layoutY="270.0"
             text="Nivel:"
             style="-fx-text-fill: #bbbbbb;
                    -fx-font-size: 18px;" />

      <Label fx:id="lbNivel"
             layoutX="250.0"
             layoutY="270.0"
             text="FÁCIL"
             style="-fx-text-fill: #ffea00;
                    -fx-font-size: 20px;
                    -fx-font-weight: bold;" />

      <!-- BOTON REINICIAR -->
      <Button layoutX="180.0"
              layoutY="340.0"
              prefWidth="120.0"
              prefHeight="40.0"
              text="JUGAR OTRA VEZ"
              onAction="#handleReiniciar"
              style="-fx-background-color: #00e676;
                     -fx-text-fill: black;
                     -fx-font-weight: bold;
                     -fx-background-radius: 12;" />

      <!-- BOTON SALIR -->
      <Button layoutX="330.0"
              layoutY="340.0"
              prefWidth="100.0"
              prefHeight="40.0"
              text="SALIR"
              onAction="#handleSalir"
              style="-fx-background-color: #ff1744;
                     -fx-text-fill: white;
                     -fx-font-weight: bold;
                     -fx-background-radius: 12;" />

   </children>

</AnchorPane>